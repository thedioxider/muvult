BOT_TOKEN=
ADMIN_TG_IDS=123456789,987654321
ND_URL=http://host.docker.internal:37510
ND_ADMIN_USER=admin
ND_ADMIN_PASS=
ND_MUSIC_PATH=/muvult
MB_SEARCH_LIMIT=48

# Own AcoustID app key for fingerprint lookups (free: https://acoustid.org/).
# Leave empty to use chroma's built-in shared key (works, but rate-limited).
ACOUSTID_API_KEY=

# Self-hosted Telegram Bot API server (lifts the 20 MB download cap to 2000 MB).
# TG_API_ID / TG_API_HASH: obtain from https://my.telegram.org (needed by the
# telegram-bot-api container). Leave BOT_API_URL empty to use the cloud API.
TG_API_ID=
TG_API_HASH=
BOT_API_URL=http://telegram-bot-api:8081
BOT_API_LOCAL=1
# Contact shown to a user if Telegram flood-control keeps stalling their uploads.
# Leave empty for generic "the bot administrator" wording.
# SUPPORT_CONTACT=@handle
